---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navigation/Navbar.astro';
import Hero from '../../components/sections/Hero.astro';
import About from '../../components/sections/About.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import CertificatesGrid from '../../components/sections/CertificatesGrid.astro';
import Footer from '../../components/sections/Footer.astro';
import WhatsAppBtn from '../../components/ui/WhatsAppBtn.astro';
import ScrolltoTop from '@/components/ui/ScrolltoTop.astro';
import { nestKeys } from '../../utils/i18n';
import Inspiration from '@/components/sections/Inspiration.astro';

import { getCollection, getEntry } from 'astro:content';

interface PersonalData {
  name: string;
  title: string;
  tagline: string;
  bio: string[];
  photo: string;
  email?: string;
  resumeUrl?: string;
  phone?: string;
  social: {
    github: string;
    linkedin: string;
    facebook?: string;
    whatsapp?: string;
  };
  titleKey?: string;
  taglineKey?: string;
  bioKeys?: string[];
}

const [projects, certificates, skills, personal] = await Promise.all([
  getCollection('projects', ({ data }) => data.status !== 'archived'),
  getCollection('certificates'),
  getCollection('skills'),
  getEntry('personal', 'main'),
]);

let t = {};
try {
  const translationsEntry = await getEntry('translations', 'en');
  t = nestKeys(translationsEntry?.data ?? {});
} catch {
  t = {};
}

projects.sort((a, b) => a.data.order - b.data.order);
certificates.sort((a, b) => a.data.order - b.data.order);
skills.sort((a, b) => a.data.order - b.data.order);

const personalData: PersonalData = personal?.data ?? {
  name: 'Kevin Alexander Meza Morales',
  title: 'Desarrollador TIC | Web Developer',
  tagline: 'Apasionado por el mundo Tecnológico, soluciones modernas y plasmar mis ideas en código.',
  bio: [],
  photo: '',
  email: 'mezamoraleskevinalexander@gmail.com',
  phone: '528112765379',
  social: {
    github: 'https://github.com/KevinAlexanderWebDev',
    linkedin: 'https://www.linkedin.com/in/kevin-meza-ecommerce-dev/',
    facebook: 'https://www.facebook.com/kevinalexander.mezamorales?locale=es_LA',
    whatsapp: '526572182791',
  },
};

const title = personalData.name ? `${personalData.name} | ${personalData.title}` : 'Portfolio | Web Developer';
const description = personalData.tagline ?? 'Professional Portfolio';
---

<Layout title={title} description={description} lang="en">
    <Navbar currentLang="en" t={t} />
    <Hero personal={personalData} t={t} currentLang="en" />
    <About personal={personalData} skills={skills} t={t} />
    <Inspiration t={t} />
    <ProjectsGrid projects={projects} t={t} />
    <CertificatesGrid certificates={certificates} t={t} currentLang="en" />
    <Footer personal={personalData} t={t} currentLang="en" />
    <WhatsAppBtn phone={personalData.social?.whatsapp} t={t} />
    <ScrolltoTop />
</Layout>