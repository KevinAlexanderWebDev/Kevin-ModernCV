---
interface Props {
  phone?: string;
  t?: any;
}

const { phone, t } = Astro.props;
const rawPhone = phone?.replace(/[^\d]/g, '') ?? '528112765379';
const formattedPhone = `+${rawPhone.slice(0, 2)} ${rawPhone.slice(2, 5)} ${rawPhone.slice(5, 8)} ${rawPhone.slice(8)}`;
const message = encodeURIComponent(`Hola, vi tu portafolio y me gustaría contactarte.`);
const whatsappUrl = `https://wa.me/${rawPhone}?text=${message}`;
const modalId = 'whatsapp-modal';
const openBtnId = 'whatsapp-open-btn';
const closeBtnId = 'whatsapp-close-btn';
const copyBtnId = 'whatsapp-copy-btn';
---

<button id={openBtnId} class="whatsapp-btn" aria-label="Contactar por WhatsApp">
  <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</button>

<div id={modalId} class="wa-modal-overlay" style="display:none" role="dialog" aria-modal="true" aria-label="Contacto WhatsApp">
  <div class="wa-modal">
    <div class="wa-modal-header">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="wa-modal-title">{t?.contacto?.title ?? 'Contacto'}</span>
      <button id={closeBtnId} class="wa-modal-close" aria-label="Cerrar">&times;</button>
    </div>
    <div class="wa-modal-body">
      <p class="wa-modal-text">{t?.contacto?.text ?? 'Siempre estoy abierto a discutir trabajo de desarrollo web o oportunidades de asociación.'}</p>
      <div class="wa-phone-display">
        <span class="wa-phone-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </span>
        <span class="wa-phone-number">{formattedPhone}</span>
      </div>
      <div class="wa-actions">
        <button id={copyBtnId} class="wa-btn wa-btn-copy" data-phone={rawPhone}>
          <span class="wa-btn-icon">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </span>
          {t?.contacto?.copy ?? 'Copiar número'}
        </button>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="wa-btn wa-btn-send">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" style="display:inline;vertical-align:middle;margin-right:6px">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t?.contacto?.send ?? 'Abrir WhatsApp'}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('whatsapp-modal');
  const openBtn = document.getElementById('whatsapp-open-btn');
  const closeBtn = document.getElementById('whatsapp-close-btn');
  const copyBtn = document.getElementById('whatsapp-copy-btn');

  function openModal() {
    if (!modal) return;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);

  copyBtn?.addEventListener('click', () => {
    const phone = copyBtn.getAttribute('data-phone');
    if (phone) {
      navigator.clipboard.writeText(`+${phone.slice(0, 2)} ${phone.slice(2)}`).then(() => {
        const originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="wa-btn-icon"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> ¡Copiado!';
        setTimeout(() => { copyBtn.innerHTML = originalText; }, 2000);
      });
    }
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.style.display === 'flex') closeModal();
  });
</script>

<style>
  .whatsapp-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    background-color: #25D366;
    color: white;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.4);
    z-index: 100;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .whatsapp-btn:hover {
    transform: scale(1.1) rotate(-5deg);
  }

  .wa-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 999;
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
  }

  .wa-modal {
    background: var(--bg-secondary, #fff);
    border-radius: var(--radius-lg, 16px);
    max-width: 420px;
    width: 100%;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
    animation: wa-modal-in 0.3s ease;
  }

  @keyframes wa-modal-in {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .wa-modal-header {
    background: linear-gradient(135deg, #25D366, #128C7E);
    color: white;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .wa-modal-title {
    font-size: 1.125rem;
    font-weight: 700;
    flex: 1;
  }

  .wa-modal-close {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    font-size: 1.5rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
  }

  .wa-modal-close:hover {
    background: rgba(255,255,255,0.35);
  }

  .wa-modal-body {
    padding: 1.5rem;
  }

  .wa-modal-text {
    color: var(--text-secondary, #555);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .wa-phone-display {
    background: var(--bg-tertiary, #f1f5f9);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-md, 12px);
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .wa-phone-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: #25D366;
    flex-shrink: 0;
  }

  .wa-phone-number {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary, #0f172a);
    letter-spacing: 0.02em;
  }

  .wa-actions {
    display: flex;
    gap: 0.75rem;
  }

  .wa-btn {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md, 12px);
    font-weight: 600;
    font-size: 0.9rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .wa-btn-copy {
    background: var(--bg-tertiary, #f1f5f9);
    color: var(--text-primary, #0f172a);
    border: 1px solid var(--border-color, #e2e8f0);
  }

  .wa-btn-copy:hover {
    background: var(--accent-glow, rgba(124,58,237,0.1));
    border-color: var(--accent-primary, #7c3aed);
  }

  .wa-btn-send {
    background: #25D366;
    color: white;
  }

  .wa-btn-send:hover {
    background: #1ebe5a;
    transform: translateY(-1px);
  }

  .wa-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .whatsapp-btn {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 50px;
      height: 50px;
    }
    
    .whatsapp-btn svg {
      width: 24px;
      height: 24px;
    }

    .wa-actions {
      flex-direction: column;
    }
  }
</style>
