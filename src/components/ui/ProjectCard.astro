---
import IconWarning from './icons/IconWarning.astro';

interface Props {
  project: any; 
  t: any;
}

const { project, t } = Astro.props;
const data = project.data;
const mobileImages = data.mobileImages || [];
const title = data.titleKey ? (t[data.titleKey] ?? data.title) : data.title;
const description = data.descriptionKey ? (t[data.descriptionKey] ?? data.description) : data.description;
---

<article class="project-card">
  <div class="card-image-wrapper">
    <div class="desktop-images">
      {data.imageObj && (
        <img
          src={data.imageObj}
          alt={title}
          class="img-primary"
          loading="lazy"
          decoding="async"
          width={600}
          height={400}
        />
      )}
      {data.hoverImageObj && (
        <img
          src={data.hoverImageObj}
          alt={`${title} - vista alternativa`}
          class="img-secondary"
          loading="lazy"
          decoding="async"
          width={600}
          height={400}
        />
      )}
      {(!data.imageObj || !data.hoverImageObj) && (
        <div class="placeholder-img">Sin Imagen</div>
      )}
    </div>

    {mobileImages.length > 0 && (
      <div class="mobile-slider" data-slider>
        {mobileImages.map((img: string, i: number) => (
          <img
            src={img}
            alt={`${title} - vista móvil ${i + 1}`}
            width={400}
            height={300}
            class={`mobile-slide ${i === 0 ? 'active' : ''}`}
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
    )}

    <div class="card-overlay">
      <div class="links">
        {data.repoUrl && <a href={data.repoUrl} target="_blank" rel="noopener noreferrer" class="social-btn">{t.see?.project?.replace('Ver ', '').replace('See ', 'Código') || 'Código'}</a>}
        {data.liveUrl && <a href={data.liveUrl} target="_blank" rel="noopener noreferrer" class="social-btn">{t.see?.project?.replace('Ver ', '').replace('See ', 'Demo') || 'Demo'}</a>}
      </div>
    </div>
  </div>

  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <div class="tags">
      {data.tags.map((tag: string) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    {data.status === 'wip' && <span class="status-badge wip"><IconWarning size={14} class="icon-inline" /> {t.proyectos?.activos || 'En Proceso'}</span>}
  </div>
</article>

<style>
  .project-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    border-color: var(--accent-primary);
  }

  .card-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--bg-tertiary);
  }

  .img-primary, .img-secondary {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease, transform 0.6s ease;
  }

  .img-secondary {
    opacity: 0;
    transform: scale(1.1);
    filter: brightness(0.7) contrast(1.2);
  }

  .project-card:hover .img-primary {
    opacity: 0;
  }

  .project-card:hover .img-secondary {
    opacity: 1;
    transform: scale(1);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 10;
  }

  .project-card:hover .card-overlay {
    opacity: 1;
  }

  .links {
    display: flex;
    gap: 1rem;
    transform: translateY(20px);
    transition: transform 0.3s ease;
  }

  .project-card:hover .links {
    transform: translateY(0);
  }

  .social-btn {
    padding: 0.5rem 1.2rem;
    background: var(--accent-primary);
    color: white;
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  .social-btn:hover {
    background: #5b21b6;
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: var(--bg-primary);
    color: var(--text-muted);
    border-radius: 9999px;
    border: 1px solid var(--border-color);
  }

  .desktop-images { display: block; }

  .mobile-slider {
    display: none;
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .mobile-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .mobile-slide.active { opacity: 1; }

  @media (max-width: 768px) {
    .desktop-images { display: none; }
    .mobile-slider { display: block; }
  }

  .status-badge { 
    display: inline-block; 
    margin-top: 1rem; 
    padding: 0.25rem 0.75rem; 
    font-size: 0.7rem; 
    font-weight: 700; 
    border-radius: 9999px; 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
  }
  .status-badge.wip { background: var(--accent-glow); color: var(--accent-primary); border: 1px solid var(--accent-primary); }
</style>

<script>
  const setupMobileSlider = () => {
    if (window.innerWidth > 768) return;
    
    const slider = document.querySelector('[data-slider]');
    if (!slider) return;
    
    const slides = slider.querySelectorAll('.mobile-slide');
    if (slides.length < 2) return;
    
    let index = 0;
    setInterval(() => {
      slides[index].classList.remove('active');
      index = (index + 1) % slides.length;
      slides[index].classList.add('active');
    }, 3000);
  };
  
  setupMobileSlider();
  document.addEventListener('astro:page-load', setupMobileSlider);
</script>