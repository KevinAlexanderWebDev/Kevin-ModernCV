---
interface Props {
  personal: any;
  skills: any[];
  t: any;
}
const {personal, skills, t} = Astro.props;
const skillsByCategory = {
  technical: skills.filter(s => s.data.category === 'technical'),
  soft: skills.filter(s => s.data.category === 'soft'),
  tools: skills.filter(s => s.data.category === 'tools'),
};
---

<section id="about" class="about-section container">
  <div class="about-grid">
    <div class="about-text">
      <h2 class="section-title">{t.about?.title || 'Sobre'}
        <span class="highlight">{t.about?.strengths?.replace('💡', '').replace('Fortalcezas y Habilidades', 'Mí') || 'Mí'}</span>
      </h2>
      {personal.bio.map((paragraph:string) => (
        <p>{paragraph}</p>
      ))}
    </div>

    <div class="skills-wrapper">
      <h3>{t.about?.skills || '🛠️ Conocimientos'}</h3>
      {Object.entries(skillsByCategory).map(([category, items]) => (
        <div class="skill-category">
          <h4 class="category-title">
            {category.charAt(0).toUpperCase() + category.slice(1)}
          </h4>
           <div class="skills-list">
            {items.map(skill => (
              <span class="skill-chip">
                {skill.data.icon && <span class="skill-icon" data-icon={skill.data.icon} />}
                {skill.data.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 6rem 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }
  
  .highlight {
    color: var(--accent-blue);
  }

  .about-text p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .skills-wrapper h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill-chip {
    padding: 0.5rem 1rem;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    border: 1px solid var(--border-color);
    transition: var(--transition);
  }

  .skill-chip:hover {
    background: var(--accent-blue);
    color: #fff;
    border-color: var(--accent-blue);
    transform: translateY(-2px);
  }

  .skill-category { margin-bottom: 2rem; }
  .category-title { 
    font-size: 1rem; 
    color: var(--text-muted); 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
    margin-bottom: 0.75rem; 
  }
  .skill-icon { display: inline-block; width: 16px; height: 16px; margin-right: 0.5rem; }

  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
