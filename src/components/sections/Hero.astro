---
import IconPin from '../ui/icons/IconPin.astro';
import { img } from '../../utils/images';
import { tr } from '../../utils/i18n';

interface Props {
  personal: any;
  t: any;
  currentLang?: string;
}

const {personal, t, currentLang = 'es'} = Astro.props;

const profileImg = personal?.photo;

const tPresentation = t.about?.presentation ?? '📌 Presentación';
const tProjectsTitle = t.proyectos?.cta ?? 'Ver Proyectos';
const tContactTitle = t.contacto?.title ?? 'Contactar';
const heroTagline = personal.taglineKey ? tr(t, personal.taglineKey, personal.tagline) : personal.tagline;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero-section container" id="home">
  <div class="hero-content">
    <div class="hero-text">
      <span class="badge">
        <IconPin size={16} /> {tPresentation}
      </span>
      <h1 class="title">
        {personal?.name ?? 'Kevin Alexander Meza Morales'} <br />
        <span class="highlight">{personal?.title ?? 'Desarrollador TIC | Web Developer'}</span>
      </h1>
      <p class="subtitle">{heroTagline}</p>
      
      <div class="cta-group">
        <a href={`${base}/${currentLang}/#projects`} class="btn btn-primary">
          {tProjectsTitle}
        </a>
        <a href={`${base}/${currentLang}/#contact`} class="btn btn-secondary">
          {tContactTitle}
        </a>
      </div>
    </div>
    
    <div class="hero-image-wrapper">
      <div class="glow-effect"></div>
      {profileImg && (
        <picture>
          <source srcset={img(profileImg.replace('.webp', '.avif'))} type="image/avif" />
          <img
            src={img(profileImg)}
            alt={personal?.name ?? 'Foto de perfil'}
            width={400}
            height={400}
            class="profile-img"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </picture>
      )}
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--accent-glow);
    color: var(--accent-primary);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(124, 58, 237, 0.2);
  }

  .title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-yellow));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-align: center;
    transition: var(--transition);
  }

  .btn-primary {
    background: var(--accent-primary);
    color: #fff;
    box-shadow: 0 4px 14px 0 rgba(124, 58, 237, 0.39);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.23);
  }

  .btn-secondary {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--bg-tertiary);
  }

  .hero-image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .glow-effect {
    position: absolute;
    width: 300px;
    height: 300px;
    background: var(--accent-yellow);
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.25;
    z-index: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .profile-img {
    position: relative;
    z-index: 1;
    border-radius: 2rem;
    object-fit: cover;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 992px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    
    .subtitle {
      margin: 0 auto 2rem auto;
    }
    
    .cta-group {
      justify-content: center;
    }
    
    .hero-image-wrapper {
      order: -1; 
    }
  }
</style>