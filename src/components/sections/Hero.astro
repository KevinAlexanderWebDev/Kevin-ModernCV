---
import { Image } from 'astro:assets';
/**
 * Importamos la imagen localmente. Astro en tiempo de compilación generará
 * diferentes tamaños, en formato next-gen (WebP/AVIF), y prevendrá el Layout Shift.
 */
import profileImg from '@/assets/images/profile.png';
---

<section class="hero-section container" id="home">
  <div class="hero-content">
    <div class="hero-text">
      <span class="badge">Disponible para nuevos retos</span>
      <h1 class="title">Construyendo el futuro de la web, un <span class="highlight">componente</span> a la vez.</h1>
      <p class="subtitle">
        Soy un Senior Frontend Developer con más de 10 años de experiencia diseñando arquitecturas robustas y pixel-perfect en el ecosistema JavaScript.
      </p>
      
      <div class="cta-group">
        <a href="#projects" class="btn btn-primary">Ver Proyectos</a>
        <a href="#contact" class="btn btn-secondary">Contactar</a>
      </div>
    </div>
    
    <div class="hero-image-wrapper">
      <div class="glow-effect"></div>
      <!-- Componente nativo de Astro. Optimización on-the-fly -->
      <Image 
        src={profileImg} 
        alt="Foto de perfil del desarrollador" 
        width={400} 
        height={400} 
        class="profile-img"
        loading="eager" 
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--accent-glow);
    color: var(--accent-blue);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(37, 99, 235, 0.2);
  }

  .title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--accent-blue), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-align: center;
    transition: var(--transition);
  }

  .btn-primary {
    background: var(--accent-blue);
    color: #fff;
    box-shadow: 0 4px 14px 0 rgba(37, 99, 235, 0.39);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.23);
  }

  .btn-secondary {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--bg-tertiary);
  }

  /* Imagen y Efectos (Premium feel) */
  .hero-image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .glow-effect {
    position: absolute;
    width: 300px;
    height: 300px;
    background: var(--accent-blue);
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.2;
    z-index: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .profile-img {
    position: relative;
    z-index: 1;
    border-radius: 2rem;
    object-fit: cover;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
    /* Border sutil glassmórfico */
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Responsive Constraints */
  @media (max-width: 992px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    
    .subtitle {
      margin: 0 auto 2rem auto;
    }
    
    .cta-group {
      justify-content: center;
    }
    
    .hero-image-wrapper {
      order: -1; /* Mueve la imagen arriba en móviles */
    }
  }
</style>
