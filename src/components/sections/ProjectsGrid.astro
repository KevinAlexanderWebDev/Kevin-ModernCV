---
import ProjectCard from '../ui/ProjectCard.astro';
import IconRocket from '../ui/icons/IconRocket.astro';

interface Props {
  projects: any[];
  t?: any;
}

const { projects, t } = Astro.props;

// Extract translation safely
const translations = t ?? {};
const baseTitle = t?.proyectos?.title ?? 'Trabajos Recientes';
const words = baseTitle.split(' ');
const lastWord = words.pop();
const isHighlighted = lastWord?.toLowerCase() === 'recientes' || lastWord?.toLowerCase() === 'projects';
const highlightClass = isHighlighted ? 'highlight' : '';
const displayWords = words;
---

<section id="projects" class="projects-section container">
  <div class="section-header">
    <h2 class="section-title">
      <IconRocket size={28} class="icon-inline" />
      {displayWords.length > 0 && (
        <span>
          {displayWords.join(' ')}
          {highlightClass ? (
            <span class={highlightClass}>
              {lastWord}
            </span>  
          ) : lastWord}
        </span>
      )}
      
      {!displayWords.length && (
        <>
          {lastWord ? (
            <span class={highlightClass}>
              {lastWord}
            </span>
          ) : {baseTitle}}
        </>
      )}
    </h2>
    <p class="section-subtitle">{t?.proyectos?.subtitle ?? 'Una selección de proyectos escalables construidos con tecnologías modernas.'}</p>
  </div>

  <div class="projects-grid">
    {projects.map(project => (
      <ProjectCard project={project} t={translations} />
    ))}
  </div>
</section>

<style>
  .projects-section {
    padding: 6rem 1.5rem;
  }

  .section-header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .highlight {
    color: var(--accent-primary);
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
</style>
