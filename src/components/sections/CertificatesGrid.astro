---
import CertificateModal from '../ui/CertificateModal.astro';
import { img } from '../../utils/images';
import { tr } from '../../utils/i18n';

interface Props {
  certificates: any[];
  t?: any;
  currentLang?: string;
}

const { certificates, t, currentLang = 'es' } = Astro.props;

// Extract certificate data with public paths
const certsData = certificates.map(cert => {
  const cd = cert.data ?? {};
  const titleKey = cd.titleKey;
  const issuerKey = cd.issuerKey;
  return {
    id: cert.id,
    title: titleKey ? tr(t, titleKey, cd.title ?? 'Certificado') : (cd.title ?? 'Certificado'),
    issuer: issuerKey ? tr(t, issuerKey, cd.issuer ?? '') : (cd.issuer ?? ''),
    issueDate: cd.issueDate ?? '',
    thumbnailPath: cd.thumbnailObj,
    imagePath: cd.imageObj,
    url: cd.url,
  };
});

const dateLocale = currentLang === 'en' ? 'en-US' : 'es-ES';
const certsTitle = t?.nav?.ct ?? 'Certificaciones';
---

<section id="certificates" class="certs-section container">
  <div class="section-header">
    <h2 class="section-title"><span class="highlight">{certsTitle}</span></h2>
  </div>

  <div class="certs-grid">
    {certsData.map(cert => (
      <article class="cert-card" data-cert-id={cert.id}>
        {cert.thumbnailPath && (
          <div class="cert-thumb-wrapper">
            <img
              src={img(cert.thumbnailPath)}
              alt={cert.title}
              width={300}
              height={200}
              class="cert-thumb"
              loading="lazy"
            />
          </div>
        )}
        <div class="cert-info">
          <h4>{cert.title}</h4>
          <p class="issuer">{cert.issuer}</p>
          <span class="date">{cert.issueDate ? new Date(cert.issueDate).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long' }) : ''}</span>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- Certificate Modal -->
<CertificateModal certificates={certsData} />

<style>
  .certs-section {
    padding: 6rem 1.5rem;
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    margin-bottom: 4rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2.5rem;
  }
  
  .highlight {
    color: var(--accent-primary);
  }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    transition: var(--transition);
  }

  .cert-card:hover {
    transform: translateX(5px);
    border-color: var(--accent-primary);
    background: var(--bg-primary);
  }

  .cert-thumb-wrapper { 
    width: 100%; 
    aspect-ratio: 3/2; 
    overflow: hidden; 
    border-radius: var(--radius-sm); 
    margin-bottom: 1rem; 
    background: var(--bg-tertiary); 
  }
  
  .cert-thumb { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    transition: transform 0.3s ease; 
  }
  .cert-card:hover .cert-thumb { transform: scale(1.05); }

  .cert-info h4 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .issuer {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>

<script define:vars={{ certsData, dateLocale }}>
  const BASE_URL = import.meta.env.BASE_URL.replace(/\/$/, '');
  const img = (p) => p && p.startsWith('/') ? BASE_URL + p : p;

  const modal = document.getElementById('cert-modal');
  const modalBody = modal?.querySelector('.modal-body');

  const certMap = Object.fromEntries(certsData.map(c => [c.id, c]));

  function openModal(certId) {
    const data = certMap[certId];
    if (!data || !modal || !modalBody) return;

    modalBody.innerHTML = `
      ${data.imagePath ? `<img src="${img(data.imagePath)}" alt="${data.title}" class="modal-image" loading="eager">` : ''}
      <div class="modal-info">
        <h3 class="modal-title">${data.title}</h3>
        <p class="modal-issuer">${data.issuer}</p>
        <p class="modal-date">${data.issueDate ? new Date(data.issueDate).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</p>
        ${data.url ? `<a href="${data.url}" target="_blank" rel="noopener" class="modal-link">Ver Certificado</a>` : ''}
      </div>
    `;

    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const card = e.target.closest('.cert-card[data-cert-id]');
    if (card) openModal(card.getAttribute('data-cert-id'));
  });

  if (modal) {
    modal.querySelectorAll('[data-close]').forEach(btn => {
      btn.addEventListener('click', closeModal);
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('open')) {
      closeModal();
    }
  });
</script>