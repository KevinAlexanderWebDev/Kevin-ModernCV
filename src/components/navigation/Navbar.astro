---
import ThemeToggle from "./ThemeToggle.astro";

// Obtenemos la url actual para saber si estamos en español o ingles (para el i18n toggle)
const { pathname } = Astro.url;
const isEnglish = pathname.startsWith("/en");

// Rutas generadas:
const togglePath = isEnglish ? "/" : "/en/";

/**
 * MASTERCLASS: Navbar Responsive c/ CSS Moderno
 * En HTML puro, tendrías un div enorme o jQuery para ocultar/mostrar el menú.
 * Aquí usaremos `<style>` encapsulado (Astro hace scope automático de las clases,
 * por lo que `.nav-links` solo aplica a este archivo y no rompe nada más en tu web).
 */
---

<header class="header">
  <div class="container nav-wrapper">
    <a href="/" class="logo" aria-label="Ir a inicio">
      <span>{`<Dev />`}</span>
    </a>

    <!-- Botón Hamburguesa para Mobile -->
    <button
      class="mobile-menu-btn"
      aria-label="Abrir menú"
      id="mobile-menu-btn"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="3" y1="12" x2="21" y2="12"></line><line
          x1="3"
          y1="6"
          x2="21"
          y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
      >
    </button>

    <nav class="nav-links" id="nav-links">
      <ul class="nav-list">
        <li><a href="#about" class="nav-item">Sobre mí</a></li>
        <li><a href="#projects" class="nav-item">Proyectos</a></li>
        <li><a href="#certificates" class="nav-item">Certificaciones</a></li>
        <li><a href="#contact" class="nav-item">Contacto</a></li>
      </ul>

      <div class="nav-actions">
        <!-- Switch de Idioma (Irá por SSG real usando astro.url) -->
        <a href={togglePath} class="lang-toggle" aria-label="Cambiar idioma">
          {isEnglish ? "ES" : "EN"}
        </a>

        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    background: var(--bg-primary);
    background-color: color-mix(in srgb, var(--bg-primary) 85%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-color);
    z-index: 50;
    display: flex;
    align-items: center;
    transition: var(--transition);
  }

  .nav-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo span {
    font-size: 1.5rem;
    font-weight: 800;
    background: linear-gradient(
      135deg,
      var(--text-primary),
      var(--accent-blue)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-list {
    display: flex;
    gap: 1.5rem;
  }

  .nav-item {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .nav-item:hover {
    color: var(--text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-left: 1px solid var(--border-color);
    padding-left: 1rem;
  }

  .lang-toggle {
    font-weight: 700;
    font-size: 0.8rem;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    background: var(--bg-tertiary);
    color: var(--text-secondary);
  }

  .lang-toggle:hover {
    background: var(--accent-blue);
    color: #fff;
  }

  .mobile-menu-btn {
    display: none;
    color: var(--text-primary);
  }

  /* MEDIA QUERIES (Mobile First Architecture invertida para desktop first aquí, pero mantenible) */
  @media (max-width: 768px) {
    .mobile-menu-btn {
      display: block;
    }

    .nav-links {
      position: absolute;
      top: 80px;
      left: 0;
      width: 100%;
      background: var(--bg-primary);
      flex-direction: column;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border-color);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      /* Oculto por defecto en mobile usando max-height en lugar de display para permitir animaciones */
      clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
      transition: clip-path 0.3s ease-out;
    }

    .nav-links.active {
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    }

    .nav-list {
      flex-direction: column;
      align-items: center;
      width: 100%;
      gap: 1rem;
    }

    .nav-actions {
      border-left: none;
      border-top: 1px solid var(--border-color);
      padding-top: 1rem;
      padding-left: 0;
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const setupMobileMenu = () => {
    const btn = document.getElementById("mobile-menu-btn");
    const nav = document.getElementById("nav-links");

    if (btn && nav) {
      const toggleMenu = () => nav.classList.toggle("active");
      btn.addEventListener("click", toggleMenu);

      const links = nav.querySelectorAll(".nav-item");
      links.forEach((link) => {
        link.addEventListener("click", () => {
          nav.classList.remove("active");
        });
      });
    }
  };

  setupMobileMenu();
  document.addEventListener("astro:page-load", setupMobileMenu);
</script>
